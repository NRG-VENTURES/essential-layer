{% comment %}
  Rotating Text Word Swap Section
  ================================
  A scroll-triggered word rotation animation using GSAP ScrollTrigger.
  The headline cycles through configurable words (brand values) as the user scrolls.

  Usage: Copy this file into your Shopify theme's sections/ directory,
  then add the section to any page via the theme customizer.
{% endcomment %}

{% unless content_for_header contains 'gsap.min.js' %}
  <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js" defer></script>
{% endunless %}

<style>
  .rtws-section {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  .rtws-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    text-align: center;
  }

  .rtws-headline {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.2;
    color: {{ section.settings.text_color }};
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0 0.3em;
  }

  .rtws-words {
    display: inline-block;
    position: relative;
    perspective: 600px;
    overflow: hidden;
    vertical-align: bottom;
  }

  .rtws-word {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    color: {{ section.settings.accent_color }};
    transform: rotateX(90deg);
    opacity: 0;
    transform-origin: center bottom;
    backface-visibility: hidden;
    will-change: transform, opacity;
    white-space: nowrap;
  }

  .rtws-word--active {
    position: relative;
    transform: rotateX(0deg);
    opacity: 1;
  }

  .rtws-subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(0.9rem, 2vw, 1.15rem);
    font-weight: 300;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    margin-top: 1.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .rtws-headline {
      font-size: clamp(1.6rem, 6vw, 2.5rem);
      flex-direction: column;
      gap: 0.2em;
    }

    .rtws-inner {
      padding: 2rem 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .rtws-headline {
      font-size: clamp(1.4rem, 7vw, 2rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rtws-word {
      position: relative !important;
      transform: none !important;
      opacity: 1 !important;
    }

    .rtws-word:not(.rtws-word--active) {
      display: none !important;
    }
  }
</style>

<section
  id="rotating-text-{{ section.id }}"
  class="rtws-section"
  aria-label="{{ section.settings.aria_label | default: 'Brand values' }}"
  data-scroll-distance="{{ section.settings.scroll_distance | default: 3 }}"
>
  <div class="rtws-inner">
    <h2 class="rtws-headline">
      <span class="rtws-prefix">{{ section.settings.headline_prefix }}</span>
      <span class="rtws-words" aria-live="polite">
        {%- for block in section.blocks -%}
          <span
            class="rtws-word{% if forloop.first %} rtws-word--active{% endif %}"
            data-index="{{ forloop.index0 }}"
            {% unless forloop.first %}aria-hidden="true"{% endunless %}
            {{ block.shopify_attributes }}
          >
            {{- block.settings.word -}}
          </span>
        {%- endfor -%}
      </span>
      <span class="rtws-suffix">{{ section.settings.headline_suffix }}</span>
    </h2>

    {% if section.settings.subtitle != blank %}
      <p class="rtws-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var sectionEl = document.getElementById('rotating-text-' + sectionId);
    if (!sectionEl) return;

    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (prefersReducedMotion.matches) return;

    function init() {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        return setTimeout(init, 100);
      }

      gsap.registerPlugin(ScrollTrigger);

      var wordsContainer = sectionEl.querySelector('.rtws-words');
      var words = sectionEl.querySelectorAll('.rtws-word');
      var totalWords = words.length;

      if (totalWords < 2) return;

      var isDesignMode = typeof Shopify !== 'undefined' && Shopify.designMode;

      function measureAndBuild() {
        var maxWidth = 0;
        var maxHeight = 0;

        words.forEach(function (word) {
          word.style.position = 'relative';
          word.style.opacity = '1';
          word.style.transform = 'none';
          word.style.visibility = 'hidden';

          var rect = word.getBoundingClientRect();
          if (rect.width > maxWidth) maxWidth = rect.width;
          if (rect.height > maxHeight) maxHeight = rect.height;

          word.style.position = '';
          word.style.opacity = '';
          word.style.transform = '';
          word.style.visibility = '';
        });

        wordsContainer.style.width = Math.ceil(maxWidth) + 'px';
        wordsContainer.style.height = Math.ceil(maxHeight) + 'px';

        if (isDesignMode) {
          buildDesignModeAnimation();
        } else {
          buildScrollAnimation();
        }
      }

      function buildScrollAnimation() {
        var scrollDistance = parseInt(sectionEl.dataset.scrollDistance, 10) || 3;

        words.forEach(function (word, i) {
          if (i === 0) {
            word.classList.add('rtws-word--active');
            gsap.set(word, { rotateX: 0, opacity: 1, position: 'relative' });
          } else {
            word.classList.remove('rtws-word--active');
            gsap.set(word, { rotateX: 90, opacity: 0, position: 'absolute' });
          }
        });

        var tl = gsap.timeline({
          scrollTrigger: {
            trigger: sectionEl,
            start: 'top top',
            end: '+=' + (scrollDistance * 100) + '%',
            pin: true,
            scrub: 0.5,
            anticipatePin: 1,
            onUpdate: function (self) {
              var progress = self.progress;
              var activeIndex = Math.min(
                Math.floor(progress * totalWords),
                totalWords - 1
              );

              words.forEach(function (word, i) {
                word.setAttribute('aria-hidden', i !== activeIndex ? 'true' : 'false');
              });
            },
          },
        });

        for (var i = 0; i < totalWords - 1; i++) {
          var segmentStart = i / (totalWords - 1);

          tl.to(
            words[i],
            {
              rotateX: -90,
              opacity: 0,
              duration: 0.4,
              ease: 'power2.inOut',
              onStart: function () {
                this.targets()[0].style.position = 'absolute';
              },
            },
            segmentStart
          );

          tl.fromTo(
            words[i + 1],
            { rotateX: 90, opacity: 0 },
            {
              rotateX: 0,
              opacity: 1,
              duration: 0.4,
              ease: 'power2.inOut',
              onStart: function () {
                this.targets()[0].style.position = 'relative';
              },
            },
            segmentStart
          );

          if (i < totalWords - 2) {
            tl.to({}, { duration: 0.3 }, segmentStart + 0.4);
          }
        }
      }

      function buildDesignModeAnimation() {
        var currentIndex = 0;

        words.forEach(function (word, i) {
          if (i === 0) {
            gsap.set(word, { rotateX: 0, opacity: 1, position: 'relative' });
          } else {
            gsap.set(word, { rotateX: 90, opacity: 0, position: 'absolute' });
          }
        });

        setInterval(function () {
          var nextIndex = (currentIndex + 1) % totalWords;

          gsap.to(words[currentIndex], {
            rotateX: -90,
            opacity: 0,
            duration: 0.6,
            ease: 'power2.inOut',
            onComplete: function () {
              words[currentIndex].style.position = 'absolute';
              currentIndex = nextIndex;
            },
          });

          gsap.fromTo(
            words[nextIndex],
            { rotateX: 90, opacity: 0 },
            {
              rotateX: 0,
              opacity: 1,
              duration: 0.6,
              ease: 'power2.inOut',
              onStart: function () {
                words[nextIndex].style.position = 'relative';
              },
            }
          );
        }, 2500);
      }

      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(measureAndBuild);
      } else {
        measureAndBuild();
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{% schema %}
{
  "name": "Rotating Text Word Swap",
  "tag": "section",
  "class": "rtws-shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "headline_prefix",
      "label": "Headline prefix",
      "default": "We make"
    },
    {
      "type": "text",
      "id": "headline_suffix",
      "label": "Headline suffix",
      "default": "possible."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle text (optional)",
      "default": "Certified organic cotton garments crafted for sensitive skin."
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Section label (accessibility)",
      "default": "Brand values"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#31403a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f3eee5"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Rotating word color",
      "default": "#ae8c71"
    },
    {
      "type": "range",
      "id": "scroll_distance",
      "label": "Scroll distance multiplier",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "info": "How many viewport heights the user scrolls through all words. Higher = slower rotation."
    }
  ],
  "blocks": [
    {
      "type": "word",
      "name": "Rotating Word",
      "settings": [
        {
          "type": "text",
          "id": "word",
          "label": "Word",
          "default": "Comfort"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rotating Text Word Swap",
      "blocks": [
        { "type": "word", "settings": { "word": "Comfort" } },
        { "type": "word", "settings": { "word": "Organic" } },
        { "type": "word", "settings": { "word": "Allergy-Free" } },
        { "type": "word", "settings": { "word": "Sustainable" } }
      ]
    }
  ]
}
{% endschema %}
